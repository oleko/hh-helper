# Скопируй в .env и заполни. Файл .env не должен попадать в git.
YANDEX_API_KEY=AQVN...

# HH.ru: зарегистрировать приложение на https://dev.hh.ru/admin → «Мои приложения» →
# создать. Это НЕ твой личный логин — отдельная сущность для API-доступа.
HH_CLIENT_ID=...
HH_CLIENT_SECRET=...

# SuperJob (опционально — можно выключить источник на странице «Настройки», если
# не нужен): зарегистрировать приложение на https://api.superjob.ru/register/,
# получишь секретный ключ (X-Api-App-Id). OAuth-авторизация работодателя не нужна —
# публичный поиск вакансий работает по одному этому ключу.
SUPERJOB_SECRET_KEY=...

# GigaChat (опционально — второй LLM-провайдер, выбирается в config.yaml → llm.*
# или на странице «Настройки» → «Модели»): Authorization key из личного кабинета
# Sber Studio (https://developers.sber.ru/studio/) → «Создать проект GigaChat API» →
# «Получить ключ». Это готовая base64-строка, ничего кодировать самому не нужно.
GIGACHAT_CREDENTIALS=...

# Логин/пароль для страницы /login веб-интерфейса (python -m src.main serve).
# Он слушает напрямую по IP VPS без TLS — выбери длинный случайный пароль,
# не тот, что используешь где-то ещё.
WEBAPP_USER=oleg
WEBAPP_PASSWORD=change-me-to-a-long-random-string

# Подписывает cookie сессии логина — длинная случайная строка, сгенерировать:
# python -c "import secrets; print(secrets.token_hex(32))"
WEBAPP_SECRET_KEY=change-me-to-a-long-random-hex-string
